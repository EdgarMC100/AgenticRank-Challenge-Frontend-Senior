# Dockerfile for LiveBoard Backend (Express SSE Server)
# This will be used by AWS App Runner

FROM node:20-alpine

# Set working directory
WORKDIR /app

# Copy package.json to install dependencies
COPY package.json ./

# Install only the required backend dependencies
# Note: express and cors are in devDependencies but needed for backend
RUN npm install --no-save express@^4.19.2 cors@^2.8.5

# Copy server directory
COPY server/ ./server/

# Create a minimal package.json with ES modules support
RUN echo '{"type":"module"}' > package.json

# Expose port 4000 (App Runner will map this)
EXPOSE 4000

# Set environment to production
ENV NODE_ENV=production

# Health check for App Runner (using wget since ES modules complicate inline Node.js)
RUN apk add --no-cache wget
HEALTHCHECK --interval=30s --timeout=3s --start-period=5s --retries=3 \
  CMD wget --no-verbose --tries=1 --spider http://localhost:4000/api/orders || exit 1

# Start the backend server
CMD ["node", "server/index.js"]
